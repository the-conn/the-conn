NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SIDEBAR_LIMIT=10
NEXT_PUBLIC_GIT_BASE_URL=https://github.com

# NEXT_PUBLIC_API_BASE_URL must be same-site as the frontend (or proxied through
# it) for the jefferies_session cookie to flow. The middleware checks for the
# cookie on the frontend origin; cross-origin dev setups will see no cookie and
# redirect-loop unless /api/* is proxied to the backend.
